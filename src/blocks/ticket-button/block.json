{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eventmesh/ticket-button",
  "title": "EventMesh ticket button",
  "category": "widgets",
  "textdomain": "eventmesh",
  "icon": "tickets-alt",
  "description": "A button linking to the current event's ticket page. Rendered directly in PHP rather than via Block Bindings, so the link is always correct regardless of binding support.",
  "keywords": ["tickets", "button", "eventmesh"],
  "usesContext": ["postId"],
  "supports": {
    "html": false,
    "shadow": true,
    "color": {
      "background": true,
      "text": true,
      "gradients": true
    },
    "typography": {
      "fontSize": true,
      "fontFamily": true,
      "__experimentalFontFamily": true,
      "fontWeight": true,
      "__experimentalFontWeight": true,
      "fontStyle": true,
      "__experimentalFontStyle": true,
      "textDecoration": true,
      "__experimentalTextDecoration": true,
      "textTransform": true,
      "__experimentalTextTransform": true,
      "letterSpacing": true,
      "__experimentalLetterSpacing": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "border": {
      "radius": true,
      "width": true,
      "color": true,
      "style": true
    }
  },
  "attributes": {
    "text": {
      "type": "string",
      "default": "Tickets"
    },
    "showPrice": {
      "type": "boolean",
      "default": true
    },
    "prefix": {
      "type": "string",
      "default": ""
    },
    "suffix": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js"
}

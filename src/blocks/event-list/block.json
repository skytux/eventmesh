{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eventmesh/event-list",
  "title": "EventMesh events list",
  "category": "widgets",
  "icon": "calendar-alt",
  "description": "Display a list of events imported by EventMesh.",
  "keywords": ["events", "calendar", "eventmesh"],
  "supports": {
    "html": false
  },
  "attributes": {
    "count": {
      "type": "number",
      "default": 6
    },
    "template": {
      "type": "string",
      "default": "events-list"
    }
  },
  "editorScript": "file:./index.js"
}

{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eventmesh/past-events-marker",
  "title": "EventMesh past events marker",
  "category": "widgets",
  "icon": "calendar-alt",
  "description": "Inside a Query Loop of events, renders a heading exactly once, right at the point where upcoming events give way to past ones. Renders nothing for every other post. Rendered directly in PHP, not via Block Bindings.",
  "keywords": ["past", "events", "divider", "eventmesh"],
  "usesContext": ["postId"],
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontFamily": true,
      "fontWeight": true,
      "fontStyle": true,
      "textDecoration": true,
      "textTransform": true,
      "letterSpacing": true,
      "textAlign": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "attributes": {
    "text": {
      "type": "string",
      "default": "Past Events"
    },
    "tag": {
      "type": "string",
      "default": "h3"
    }
  },
  "editorScript": "file:./index.js"
}
